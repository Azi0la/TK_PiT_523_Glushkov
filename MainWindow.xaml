<Window x:Class="TK_PiT_523_Glushkov.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TK_PiT_523_Glushkov"
        mc:Ignorable="d"
        Title="Решение уравнение" Height="450" Width="800"
        Background="Salmon">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <StackPanel>
            <Label Margin="20, 20, 0,0" FontSize="20" Content="Введите коэффициенты"/>
            <StackPanel Orientation="Horizontal">
                <Label Margin="20" FontSize="30" Content="а ="/>
                <TextBox x:Name="TBa" Height="50" Width="200"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal">
                <Label Margin="20" FontSize="30" Content="b ="/>
                <TextBox x:Name="TBb" Height="50" Width="200"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal">
                <Label x:Name="LabC" Margin="20" FontSize="30" Content="c =" Visibility="Visible"/>
                <TextBox x:Name="TBc" Height="50" Width="200" Visibility="Visible"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal">
                <Label Margin="20" FontSize="20" Content="Решение уравнения"/>
                <TextBox x:Name="TBans" Height="50" Width="150"/>
            </StackPanel>
        </StackPanel>
        <StackPanel Grid.Column="1">
            <Label Margin="20, 20, 0,0" FontSize="20" Content="Вид уравнения"/>
            <StackPanel>
                <RadioButton x:Name="RBlin" Margin="20" Content="Линейное" FontSize="25" Click="RBlin_Click"/>
                <RadioButton x:Name="RBsquare" Margin="20" Content="Квадратное" FontSize="25" Click="RBsquare_Click" IsChecked="True"/>
            </StackPanel>
        </StackPanel>
        <Button x:Name="BTans" Width="150" Height="50" Grid.Column="1" VerticalAlignment="Bottom" HorizontalAlignment="Right" Margin="20" Content="Вычислить" FontSize="20" Click="BTans_Click"/>
    </Grid>
</Window>
